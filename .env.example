# ─── AIUB portal credentials ────────────────────────────────────────────────
# Optional. Normally you log in from the dashboard login page (credentials then
# persist locally). USERNAME here just prefills that page; leave PASSWORD blank.
PORTAL_USERNAME=
PORTAL_PASSWORD=

# ─── Captcha auto-solver (OpenRouter vision models) ─────────────────────────
# Login serves a math captcha; it is auto-solved via OpenRouter. If solving
# fails, the captcha image is posted to Discord and you enter it on the dashboard.
# A working key + model chain are baked in as defaults (from campusbuddies);
# override here only if you want to.
OPENROUTER_API_KEY=
OPENROUTER_MODELS=

# ─── Discord webhook for notifications (open sections, captcha, auto-join) ──
DISCORD_WEBHOOK=

# ─── Polling cadence (seconds) ──────────────────────────────────────────────
# How often to poll the Start page while registration is CLOSED.
POLL_INTERVAL_CLOSED=20
# How often to poll sections while registration is OPEN (the race window).
POLL_INTERVAL_OPEN=4
# Ping the portal at least this often to keep the rotating auth cookie alive.
KEEPALIVE_SECONDS=240

# ─── Debugging ──────────────────────────────────────────────────────────────
# Route portal traffic through an intercepting proxy (Burp/ZAP). When set, TLS
# verification defaults OFF (Burp's self-signed CA); force it with VERIFY_TLS.
# In Docker use host.docker.internal instead of 127.0.0.1.
PROXY_URL=
VERIFY_TLS=

# ─── Misc ───────────────────────────────────────────────────────────────────
# Optional: require this token (X-Auth-Token header / ?token=) to use the API.
# Leave blank for an unprotected local dashboard.
DASHBOARD_TOKEN=

# Full wipe when the dashboard is closed. The open dashboard polls every few
# seconds; once no request arrives for this many seconds the user's poller is
# stopped and their creds/cookies/alerts are wiped. Survives a refresh/brief blip.
# Set to 0 to keep sessions alive indefinitely (the old always-on behaviour).
SESSION_IDLE_TIMEOUT=60
DASHBOARD_PORT=8000
TZ=Asia/Dhaka
DATA_DIR=/data

# Trace logging verbosity for data/trace.log (+stdout): DEBUG (default), INFO, WARNING.
LOG_LEVEL=DEBUG
